# ══════════════════════════════════════════════════════════════════════
# ÉTAPE 2 — Fusion de playlist
# ══════════════════════════════════════════════════════════════════════

def _strip_login_for_repetition(app: dict) -> dict:
    """
    Sur les passages > 1 d'une playlist, on retire le login pour éviter
    la répétition inutile (et potentiellement bloquante).
    """
    copy = dict(app)
    if copy.get("url_entree"):
        copy["url_entree"] = None
        copy["sequence"] = []
    else:
        copy["sequence"] = [
            act for act in copy.get("sequence", [])
            if act.get("action") != "smart_login"
        ]
    return copy


def _find_config_path(target_name: str, available_configs: dict[str, str]) -> Optional[str]:
    """
    Cherche le chemin d'une config par nom de fichier ou display_name.
    `available_configs` est le dict retourné par list_configs_hierarchical.
    """
    import os
    for display_name, path in available_configs.items():
        if os.path.basename(path) == target_name or display_name == target_name:
            return path
    return None


