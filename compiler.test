
"""
compiler.py — Pipeline de compilation des configurations kiosk.

"""

import os
from typing import Optional

from loguru import logger

import config as cfg
import skills
from skills import SkillError, SkillNotFoundError


class CompilationError(Exception):
    """Erreur lors de la compilation d'une config (résolution ou fusion)."""


# ══════════════════════════════════════════════════════════════════════
# ÉTAPE 1 — Résolution des SkillRef en Application
# ══════════════════════════════════════════════════════════════════════

def _skill_to_application(skill_data: dict, temps_affichage: int) -> dict:
    """
    Fusionne un skill + son contexte d'affichage pour produire une Application
    au format attendu par l'engine.
    """
    app = {
        "nom": skill_data.get("nom", ""),
        "type": skill_data.get("type", "web"),
        "source": skill_data.get("source", ""),
        "url_entree": skill_data.get("url_entree"),
        "temps_affichage": temps_affichage,
        "refresh_auto": skill_data.get("refresh_auto", True),
        "fenetre_classe": skill_data.get("fenetre_classe"),
        "sequence": list(skill_data.get("sequence", [])),
    }
    return app


# Permet de désactiver la conversion PPT→Web (tests, debug) sans toucher au code.
_ENV_DISABLE_PPT_RENDER = "KIOSK_DISABLE_PPT_RENDER"


def _maybe_render_ppt(app: dict, duree_diapo: Optional[int] = None,
                      boucles: int = 1) -> dict:
    """Transforme une Application 'ppt' en page web locale (diapos en images).

    PowerPoint ne joue qu'un seul diaporama à la fois : pour autoriser l'affichage
    simultané d'un même .pptx (ou de .pptx différents) sur plusieurs écrans, on
    exporte les diapos en images et on les diffuse comme une page web via le chemin
    Chrome par moniteur (qui gère déjà le multi-écran). Voir ppt_render.py.

    Le temps d'affichage est CALCULÉ : durée d'un cycle (durée/diapo × nb diapos, ou
    minutages du fichier) × nombre de boucles. 'duree_diapo' est prioritaire si fournie.

    Lève CompilationError si la conversion échoue : l'engine ne sait pas afficher un
    'ppt' brut, donc un message clair au démarrage vaut mieux qu'une erreur runtime.
    """
    if app.get("type") != "ppt":
        return app

    # Bypass debug/test : laisse l'app 'ppt' telle quelle (non convertie).
    if os.getenv(_ENV_DISABLE_PPT_RENDER):
        return app

    try:
        import ppt_render
    except Exception as e:
        raise CompilationError(
            f"Diaporama '{app.get('nom')}' : module 'ppt_render' introuvable ({e}). "
            f"Vérifie qu'il est déployé à la racine du projet."
        ) from e

    result = ppt_render.render_ppt_to_web(
        app.get("source", ""),
        duree_diapo=duree_diapo,
        boucles=boucles,
    )
    if not result:
        raise CompilationError(
            f"Diaporama '{app.get('nom')}' : conversion impossible. "
            f"PowerPoint est-il installé ? Le fichier est-il accessible et valide ? "
            f"(source = '{app.get('source')}')"
        )

    web_app = dict(app)
    web_app["type"] = "web"
    web_app["source"] = "file:///" + result["html"].replace("\\", "/")
    web_app["temps_affichage"] = result["duree_totale_s"]
    web_app["url_entree"] = None
    web_app["refresh_auto"] = False  # le carrousel JS tourne en continu (pas de reload)
    web_app["fenetre_classe"] = None
    web_app["sequence"] = []
    return web_app


