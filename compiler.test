def resolve_skill_refs(base_dir: str, raw_config: dict,
                       site: Optional[str] = None,
                       workspace: Optional[str] = None,
                       default_monitor: int = 1) -> dict:
    out = dict(raw_config)
    if raw_config.get("type") == "playlist":
        return out

    apps_raw = raw_config.get("applications", []) or []
    apps_out = []
    missing_refs = []

    for app_idx, ref in enumerate(apps_raw):
        if not isinstance(ref, dict) or "skill" not in ref:
            missing_refs.append(f"app #{app_idx + 1}: référence skill manquante")
            continue

        ref_str = ref["skill"]
        temps = ref.get("temps_affichage", 30)
        duree_diapo = ref.get("duree_diapo")
        boucles = ref.get("boucles", 1)

        try:
            skill_data = skills.load_skill(base_dir, ref_str, site, workspace)
            app = _skill_to_application(skill_data, temps)
            apps_out.append(_maybe_render_ppt(app, duree_diapo=duree_diapo, boucles=boucles))
        except Exception as e:
            missing_refs.append(f"app #{app_idx + 1} : {e}")
            continue

    if missing_refs:
        detail = "\n  - ".join(missing_refs)
        raise CompilationError(f"Impossible de résoudre {len(missing_refs)} référence(s) :\n  - {detail}")

    if not apps_out:
        raise CompilationError("La configuration ne contient aucune application valide.")

    # On recrée la structure 'affichage_config' requise par engine.py
    out["affichage_config"] = [{"monitor_index": default_monitor, "applications": apps_out}]
    out.pop("applications", None)
    return out


def _merge_playlist(base_dir: str, raw_config: dict, global_config: dict,
                    site: Optional[str], workspace: Optional[str]) -> dict:
    items = raw_config.get("items") or []
    if not items: raise CompilationError("La playlist est vide.")

    logger.info("🔄 PLAYLIST : Fusion des configurations en mémoire...")
    available_configs = cfg.list_carousels_hierarchical(base_dir, site, workspace)
    merged_monitors: dict[int, list] = {}
    merged_global_params = dict(raw_config.get("parametres_globaux", {}))
    erreurs_details = []

    for item in items:
        target_name = item.get("config", "")
        passages = int(item.get("passages", 1) or 1)
        monitor_idx = int(item.get("monitor_index", 1))

        sub_path = _find_config_path(target_name, available_configs)
        if not sub_path:
            erreurs_details.append(f"❌ '{target_name}' : Fichier introuvable.")
            continue

        try:
            sub_raw = cfg.charger_config(sub_path, global_config)
            # On passe le monitor_idx au compilateur pour qu'il l'injecte
            sub_compiled = compile_config(base_dir, sub_raw, global_config, site, workspace, False, monitor_idx)

            for k, v in sub_compiled.get("parametres_globaux", {}).items():
                if k not in merged_global_params: merged_global_params[k] = v

            for ecran in sub_compiled.get("affichage_config") or []:
                m_idx = ecran["monitor_index"]
                apps = ecran.get("applications", [])
                for p in range(passages):
                    for original_app in apps:
                        app_copy = dict(original_app) if p == 0 else _strip_login_for_repetition(original_app)
                        merged_monitors.setdefault(m_idx, []).append(app_copy)

        except Exception as e:
            erreurs_details.append(f"❌ '{target_name}' : {e}")

    affichage_final = [{"monitor_index": m, "applications": a} for m, a in merged_monitors.items() if a]
    if not affichage_final:
        raise CompilationError("La playlist n'a généré aucune application.\n" + "\n".join(erreurs_details))

    return {"type": "kiosk", "parametres_globaux": merged_global_params, "affichage_config": affichage_final}


def compile_config(base_dir: str, raw_config: dict, global_config: dict,
                   site: Optional[str] = None, workspace: Optional[str] = None,
                   _allow_nested_playlist: bool = True, default_monitor: int = 1) -> dict:
    config_type = raw_config.get("type", "kiosk")
    if config_type == "playlist":
        if not _allow_nested_playlist:
            raise CompilationError("Playlist imbriquée interdite.")
        return _merge_playlist(base_dir, raw_config, global_config, site, workspace)
    return resolve_skill_refs(base_dir, raw_config, site, workspace, default_monitor)

