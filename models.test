
"""
models.py — Modèles de données Pydantic pour Kiosk Engine.

Architecture à 2 niveaux :
  - RawKioskConfig : ce que l'utilisateur édite (avec SkillRef)
  - KioskConfig    : ce que l'engine consomme (avec Application complète, après compilation)

Un "skill" est une brique métier réutilisable (type + source + séquence RPA).
Une "config" contextualise un skill dans un écran avec une durée d'affichage.
La résolution des SkillRef en Application est faite par compiler.resolve_skill_refs().
"""

from typing import List, Optional, Literal, Dict, Any
from pydantic import BaseModel, Field


# ──────────────────────────────────────────────────────────────────
# Primitives partagées (skills ET applications post-compilation)
# ──────────────────────────────────────────────────────────────────

class Identifiants(BaseModel):
    user: str = ""
    pass_secret: str = Field(default="", alias="pass")


class Selecteurs(BaseModel):
    user_id: str = (
        "//input[not(@type) or @type='text' or @type='email']"
        "[contains(@name,'user') or contains(@name,'login') or contains(@placeholder,'User') or contains(@placeholder,'Email') or contains(@placeholder,'Identifiant')] | "
        "//input[@name='user[email]']"
    )
    pass_id: str = "//input[@type='password']"
    btn: str = (
        "//button[@type='submit'] | //input[@type='submit'] | "
        "//*[contains(text(), 'SIGN IN')] | //*[contains(text(), 'Login')] | //*[contains(text(), 'Connexion')]"
    )

class Action(BaseModel):
    action: Literal["click", "fill", "smart_login", "sleep", "send_keys",
                    "click_all", "fill_select", "switch_iframe", "switch_default"]
    by: Optional[Literal["xpath", "id", "index", "none"]] = "xpath"
    selector: Optional[str] = ""
    value: Optional[str] = ""
    identifiants: Optional[Identifiants] = None
    selecteurs: Optional[Selecteurs] = None


# ──────────────────────────────────────────────────────────────────
# SKILL — brique métier réutilisable (stockée dans skills/<nom>.json)
# ──────────────────────────────────────────────────────────────────

class Skill(BaseModel):
    """
    Brique métier atomique et réutilisable.
    Ne contient PAS la durée d'affichage ni le monitor_index : ces champs
    sont contextuels à chaque utilisation (→ SkillRef dans la config).
    """
    nom: str = Field(..., description="Identifiant du skill (nom du fichier)")
    type: Literal["web", "desktop_app", "ppt"] = "web"
    source: str = Field(..., description="URL de destination (web) ou chemin exécutable (desktop)")
    url_entree: Optional[str] = None
    refresh_auto: bool = True
    fenetre_classe: Optional[str] = None
    sequence: List[Action] = Field(default_factory=list)


# ──────────────────────────────────────────────────────────────────
# CONFIG BRUTE (édition) — référence des skills par nom
# ──────────────────────────────────────────────────────────────────

class SkillRef(BaseModel):
    """
    Référence vers un skill + contexte d'affichage.
    Le champ 'skill' accepte 3 syntaxes :
      - "mon_skill"          → résolu en cascade WS > SITE > GLOBAL
      - "@WS/mon_skill"      → force le workspace courant
      - "@SITE/mon_skill"    → force le site courant
      - "@GLOBAL/mon_skill"  → force le niveau global
    """
    skill: str = Field(..., description="Nom du skill, optionnellement préfixé @WS/@SITE/@GLOBAL")
    temps_affichage: int = Field(default=30, gt=0)


# class EcranRaw(BaseModel):
#     """Écran tel qu'il est édité par l'utilisateur (avec SkillRef)."""
#     monitor_index: int = Field(default=1, ge=1)
#     applications: List[SkillRef] = Field(..., min_length=1)
#
#
# class PlaylistItem(BaseModel):
#     config: str
#     passages: int = Field(default=1, gt=0)
#
#
# class RawKioskConfig(BaseModel):
#     """
#     Config telle qu'elle est stockée sur disque et éditée dans le Content Hub.
#     Sera compilée en KioskConfig (avec applications résolues) au démarrage.
#     """
#     type:
#     Literal["kiosk", "playlist"] = "kiosk"
#     parametres_globaux: Dict[str, Any] = Field(default_factory=dict)
#     affichage_config: Optional[List[EcranRaw]] = None
#     items: Optional[List[PlaylistItem]] = None

class SkillRef(BaseModel):
    skill: str = Field(..., description="Nom du skill, optionnellement préfixé @WS/@SITE/@GLOBAL")
    temps_affichage: int = Field(default=30, gt=0)
    # Champs spécifiques aux skills 'ppt' (ignorés pour web / desktop_app) :
    duree_diapo: Optional[int] = Field(
        default=None, ge=1,
        description="PPT : durée fixe par diapo (s), prioritaire sur les minutages du fichier")
    boucles: int = Field(
        default=1, ge=1,
        description="PPT : nombre de défilements complets du diaporama avant l'élément suivant")

class PlaylistItem(BaseModel):
    config: str
    passages: int = Field(default=1, gt=0)
    monitor_index: int = Field(default=1, ge=1)  # L'index d'écran est maintenant ici !

class RawKioskConfig(BaseModel):
    """Config telle qu'elle est éditée (Carousel = liste de skills)."""
    type: Literal["kiosk", "playlist"] = "kiosk"
    parametres_globaux: Dict[str, Any] = Field(default_factory=dict)
    applications: Optional[List[SkillRef]] = None  # Remplace affichage_config
    items: Optional[List[PlaylistItem]] = None



# ──────────────────────────────────────────────────────────────────
# CONFIG COMPILÉE (runtime) — consommée par engine.py
# ──────────────────────────────────────────────────────────────────

class Application(BaseModel):
    """
    Application concrète prête à être exécutée par un moniteur.
    Résulte de la fusion d'un Skill + contexte (temps_affichage de la SkillRef).
    L'engine ne voit que ce format (pas de SkillRef).
    """
    nom: str = Field(..., description="Nom d'affichage (hérité du skill)")
    type: Literal["web", "desktop_app", "ppt"] = "web"
    source: str
    url_entree: Optional[str] = None
    temps_affichage: int = Field(default=30, gt=0)
    refresh_auto: bool = True
    fenetre_classe: Optional[str] = None
    sequence: List[Action] = Field(default_factory=list)


class Ecran(BaseModel):
    monitor_index: int = Field(default=1, ge=1)
    applications: List[Application] = Field(..., min_length=1)


class KioskConfig(BaseModel):
    """Config post-compilation consommée par engine.py."""
    type: Literal["kiosk", "playlist"] = "kiosk"
    parametres_globaux: Dict[str, Any] = Field(default_factory=dict)
    affichage_config: Optional[List[Ecran]] = None
    items: Optional[List[PlaylistItem]] = None


