"""
main.py — Point d'entrée de Kiosk Engine.

Usage:
    python main.py [base_dir] [--autorun config.json] [--site X] [--workspace Y]

Pipeline de démarrage :
    1. Parse CLI + init DPI + logger
    2. Résolution scope RBAC (user → role, site, workspace)
    3. Sélection config (autorun ou sélecteur)
    4. Validation Pydantic + compilation (résolution skills + fusion playlist)
    5. Validation sécurité (domaines, exec, send_keys)
    6. Splash + bannière + threads moniteurs + control panel
"""

import sys
import os
import time
import tkinter as tk
import subprocess
import threading
import ctypes
import socket

from loguru import logger

import sys
import os
import ctypes
import tkinter as tk
from tkinter import messagebox

def _appliquer_securites_demarrage(base_dir: str):
    """
    Applique les 3 barrières de sécurité indispensables avant le démarrage :
    1. Anti-doublon (Mutex)
    2. Verrou d'emplacement
    3. Disponibilité du serveur
    """
    # On ignore ces blocages si on lance le script en mode développeur (.py)
    if not getattr(sys, 'frozen', False):
        return

    mutex_name = "Global\\KioskEngine_App_Mutex_Lock"
    kernel32 = ctypes.windll.kernel32
    kernel32.CreateMutexW(None, False, mutex_name)
    if kernel32.GetLastError() == 183:
        sys.exit(0)


    chemin_actuel = os.path.abspath(sys.executable).lower()
    dossier_attendu = os.path.join(os.getenv('LOCALAPPDATA'), "KioskEngine_App")
    chemin_attendu = os.path.join(dossier_attendu, "KioskEngine.exe").lower()

    if chemin_actuel != chemin_attendu:
        _afficher_erreur_critique(
            "Lancement non autorisé",
            "Le Kiosk Engine ne peut pas être exécuté depuis cet emplacement.\n"
            "Veuillez utiliser le script de démarrage officiel.\n\n"
            f"Chemin actuel : {chemin_actuel}"
        )

    if not os.path.exists(base_dir):
        _afficher_erreur_critique(
            "Panne Réseau",
            "Impossible de joindre le serveur principal.\n"
            "Vérifiez votre connexion réseau (ou le VPN) avant de relancer l'application.\n\n"
            f"Chemin inaccessible : {base_dir}"
        )

def _afficher_erreur_critique(titre: str, message: str):
    """Affiche une popup d'erreur native et tue le processus."""
    root = tk.Tk()
    root.withdraw()  # Masque la fenêtre grise vide derrière la popup
    root.attributes("-topmost", True)  # Force la popup au premier plan
    messagebox.showerror(titre, message)
    sys.exit(1)

_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
if _SCRIPT_DIR not in sys.path:
    sys.path.insert(0, _SCRIPT_DIR)


try:
    ctypes.windll.shcore.SetProcessDpiAwareness(2)
except Exception:
    pass

try:
    myappid = 'airbus.kioskengine.app.1.0'
    ctypes.windll.shell32.SetCurrentProcessExplicitAppUserModelID(myappid)
except Exception:
    pass

