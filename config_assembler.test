    def _build_screens_block(self, parent):
        card = tk.Frame(parent, bg=Colors.BG_WHITE, highlightbackground=Colors.BORDER, highlightthickness=1)
        card.pack(fill=tk.BOTH, expand=True)

        header = tk.Frame(card, bg=Colors.BG_WHITE, padx=16, pady=10)
        header.pack(fill=tk.X)
        tk.Label(header, text="Séquence de skills", font=(Fonts.MAIN, 10, "bold"), fg=Colors.TXT,
                 bg=Colors.BG_WHITE).pack(side=tk.LEFT)
        AirbusButton(header, "+ Ajouter un skill", bg=Colors.BLUE, font_size=9, command=self._add_skill).pack(
            side=tk.RIGHT)

        tk.Frame(card, bg=Colors.BORDER_LIGHT, height=1).pack(fill=tk.X)

        canvas = tk.Canvas(card, bg=Colors.BG_WHITE, highlightthickness=0, height=300)
        scrollbar = ttk.Scrollbar(card, orient="vertical", command=canvas.yview)
        self.screens_frame = tk.Frame(canvas, bg=Colors.BG_WHITE, padx=12, pady=8)
        self.screens_frame.bind("<Configure>", lambda e: canvas.configure(scrollregion=canvas.bbox("all")))
        self._screens_window = canvas.create_window((0, 0), window=self.screens_frame, anchor="nw")
        canvas.bind("<Configure>", lambda e: canvas.itemconfig(self._screens_window, width=e.width))
        canvas.configure(yscrollcommand=scrollbar.set)
        canvas.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
        scrollbar.pack(side=tk.RIGHT, fill=tk.Y)

    def _refresh_screens(self):
        for w in self.screens_frame.winfo_children(): w.destroy()

        apps = self.draft.get("applications") or []
        if not apps:
            tk.Label(self.screens_frame, text="(aucun skill — cliquez sur « + Ajouter un skill »)",
                     font=(Fonts.MAIN, 9), fg=Colors.TXT_3, bg=Colors.BG_WHITE).pack(pady=14)
        else:
            for j, app in enumerate(apps): self._render_app_row(self.screens_frame, j, app)

        self.screens_frame.update_idletasks()
        if hasattr(self, 'screens_frame') and hasattr(self.screens_frame, 'master'):
            self.screens_frame.master.configure(scrollregion=self.screens_frame.master.bbox("all"))
            self.screens_frame.master.yview_moveto(0)

    def _skill_type(self, ref: str) -> str:
        """Type du skill référencé ('web' | 'desktop_app' | 'ppt').

        Renvoie 'web' par défaut (ou si le skill est introuvable) : le minutage
        standard 'durée (s)' reste alors la valeur sûre.
        """
        try:
            return skills.load_skill(self.base_dir, ref, self.site, self.workspace).get("type", "web")
        except Exception:
            return "web"

    def _render_web_timing(self, inner, app_idx: int, app: dict):
        """Champ 'durée (s)' pour un élément web / desktop_app (comportement existant)."""
        duree_var = tk.StringVar(value=str(app.get("temps_affichage", 30)))

        def _on_duree_change(*_):
            try:
                v = int(duree_var.get())
                if v > 0:
                    self.draft["applications"][app_idx]["temps_affichage"] = v
                    self._mark_dirty()
            except ValueError:
                pass

        duree_var.trace_add("write", _on_duree_change)
        tk.Label(inner, text="durée (s) :", font=(Fonts.MAIN, 8), fg=Colors.TXT_2,
                 bg=Colors.BG_PAGE).pack(side=tk.LEFT, padx=(16, 3))
        tk.Entry(inner, textvariable=duree_var, font=(Fonts.MONO, 9), width=5,
                 bg=Colors.BG_WHITE, relief="solid", bd=1).pack(side=tk.LEFT)

    def _render_ppt_timing(self, inner, app_idx: int, app: dict):
        """Champs 'durée/diapo' + 'boucles' pour un diaporama (ppt).

        Le temps d'affichage de l'élément est recalculé à la compilation :
        durée/diapo × nb de diapos × nb de boucles.
        """
        diapo_var = tk.StringVar(value=str(app.get("duree_diapo", 8)))
        boucles_var = tk.StringVar(value=str(app.get("boucles", 1)))

        def _on_diapo_change(*_):
            try:
                v = int(diapo_var.get())
                if v >= 1:
                    self.draft["applications"][app_idx]["duree_diapo"] = v
                    self._mark_dirty()
            except ValueError:
                pass

        def _on_boucles_change(*_):
            try:
                v = int(boucles_var.get())
                if v >= 1:
                    self.draft["applications"][app_idx]["boucles"] = v
                    self._mark_dirty()
            except ValueError:
                pass

        diapo_var.trace_add("write", _on_diapo_change)
        boucles_var.trace_add("write", _on_boucles_change)
        tk.Label(inner, text="durée/diapo (s) :", font=(Fonts.MAIN, 8), fg=Colors.TXT_2,
                 bg=Colors.BG_PAGE).pack(side=tk.LEFT, padx=(16, 3))
        tk.Entry(inner, textvariable=diapo_var, font=(Fonts.MONO, 9), width=4,
                 bg=Colors.BG_WHITE, relief="solid", bd=1).pack(side=tk.LEFT)
        tk.Label(inner, text="boucles :", font=(Fonts.MAIN, 8), fg=Colors.TXT_2,
                 bg=Colors.BG_PAGE).pack(side=tk.LEFT, padx=(10, 3))
        tk.Entry(inner, textvariable=boucles_var, font=(Fonts.MONO, 9), width=3,
                 bg=Colors.BG_WHITE, relief="solid", bd=1).pack(side=tk.LEFT)

    def _render_app_row(self, parent, app_idx: int, app: dict):
        row = tk.Frame(parent, bg=Colors.BG_PAGE, highlightbackground=Colors.BORDER_LIGHT, highlightthickness=1)
        row.pack(fill=tk.X, padx=8, pady=(0, 4))
        inner = tk.Frame(row, bg=Colors.BG_PAGE, padx=10, pady=6)
        inner.pack(fill=tk.X)

        tk.Label(inner, text=f"{app_idx + 1}.", font=(Fonts.MONO, 8), fg=Colors.TXT_3, bg=Colors.BG_PAGE).pack(
            side=tk.LEFT)
        ref = app.get("skill", "?")

        try:
            scope, _ = skills.resolve_skill_ref(self.base_dir, ref, self.site, self.workspace)
            lbl = f"→ {scope}"
        except Exception:
            lbl = "→ introuvable !"

        tk.Label(inner, text=ref, font=(Fonts.MONO, 9, "bold"), fg=Colors.BLUE, bg=Colors.BG_PAGE).pack(side=tk.LEFT,
                                                                                                        padx=(8, 0))
        tk.Label(inner, text=lbl, font=(Fonts.MAIN, 8), fg=Colors.TXT_3, bg=Colors.BG_PAGE).pack(side=tk.LEFT,
                                                                                                 padx=(8, 0))

        # Minutage adapté au type : ppt → durée/diapo + boucles, sinon → durée (s)
        if self._skill_type(ref) == "ppt":
            self._render_ppt_timing(inner, app_idx, app)
        else:
            self._render_web_timing(inner, app_idx, app)

        AirbusButton(inner, "✕", bg=Colors.RED, font_size=8, command=lambda a=app_idx: self._del_app(a)).pack(
            side=tk.RIGHT)
        AirbusButton(inner, "▼", outline=True, font_size=8, command=lambda a=app_idx: self._move_app(a, +1)).pack(
            side=tk.RIGHT, padx=(0, 3))
        AirbusButton(inner, "▲", outline=True, font_size=8, command=lambda a=app_idx: self._move_app(a, -1)).pack(
            side=tk.RIGHT, padx=(0, 3))

    def _add_skill(self):
        if not self._available_skills:
            messagebox.showwarning("Aucun skill", "Créez d'abord un skill.", parent=self)
            return

        # 🚨 FIX ANTI-FREEZE : On relâche la fenêtre parente
        self.grab_release()
        self.attributes('-topmost', False)

        # --- Nouvelle fenêtre Airbus ---
        dlg = tk.Toplevel(self)
        apply_borderless(dlg)
        dlg.configure(bg=Colors.BG_PAGE)
        dlg.attributes('-topmost', True)
        dlg.transient(self)

        NavBar(dlg, "Ajout requis", "Ajouter un skill", close_command=dlg.destroy, show_close=True)

        body = tk.Frame(dlg, bg=Colors.BG_PAGE, padx=20, pady=20)
        body.pack(fill=tk.BOTH, expand=True)

        tk.Label(body, text="Skill à référencer :", font=(Fonts.MAIN, 10), fg=Colors.TXT, bg=Colors.BG_PAGE).pack(
            anchor="w", pady=(0, 4))

        # Emojis automatiques
        emoji_map = {"GLOBAL": "🌍", "SITE": "🏭", "WS": "🏢️"}
        values = [f"{emoji_map.get(info['scope'], info['scope'])} {name}" for name, info in
                  sorted(self._available_skills.items())]

        combo = ttk.Combobox(body, values=values, state="readonly", width=38, style="AB.TCombobox")
        combo.pack(fill=tk.X)
        if values: combo.set(values[0])

        tk.Label(body, text="Préfixe (optionnel) :", font=(Fonts.MAIN, 9), fg=Colors.TXT_2, bg=Colors.BG_PAGE).pack(
            anchor="w", pady=(10, 2))
        force_var = tk.StringVar(value="Auto")
        force_combo = ttk.Combobox(body, textvariable=force_var, state="readonly",
                                   values=["Auto", "🏢️ @WS", "🏭 @SITE", "🌍 @GLOBAL"], width=38, style="AB.TCombobox")
        force_combo.pack(fill=tk.X)

        # Minutage adapté au type de skill sélectionné (rafraîchi à chaque choix).
        timing_holder = tk.Frame(body, bg=Colors.BG_PAGE)
        timing_holder.pack(fill=tk.X)

        duree_var = tk.StringVar(value="30")
        diapo_var = tk.StringVar(value="8")
        boucles_var = tk.StringVar(value="1")
        ctx = {"type": "web"}

        def _render_timing(event=None):
            for child in timing_holder.winfo_children():
                child.destroy()
            raw = combo.get()
            name_sel = raw.split(" ", 1)[-1].strip() if raw else ""
            ctx["type"] = self._skill_type(name_sel) if name_sel else "web"

            if ctx["type"] == "ppt":
                tk.Label(timing_holder, text="Durée par diapo (s) :", font=(Fonts.MAIN, 9),
                         fg=Colors.TXT_2, bg=Colors.BG_PAGE).pack(anchor="w", pady=(10, 2))
                tk.Entry(timing_holder, textvariable=diapo_var, font=(Fonts.MONO, 10),
                         bg=Colors.BG_WHITE, relief="solid", bd=1, width=10).pack(anchor="w", ipady=2)
                tk.Label(timing_holder, text="Boucles du diaporama :", font=(Fonts.MAIN, 9),
                         fg=Colors.TXT_2, bg=Colors.BG_PAGE).pack(anchor="w", pady=(10, 2))
                tk.Entry(timing_holder, textvariable=boucles_var, font=(Fonts.MONO, 10),
                         bg=Colors.BG_WHITE, relief="solid", bd=1, width=10).pack(anchor="w", ipady=2)
            else:
                tk.Label(timing_holder, text="Durée (s) :", font=(Fonts.MAIN, 9),
                         fg=Colors.TXT_2, bg=Colors.BG_PAGE).pack(anchor="w", pady=(10, 2))
                tk.Entry(timing_holder, textvariable=duree_var, font=(Fonts.MONO, 10),
                         bg=Colors.BG_WHITE, relief="solid", bd=1, width=10).pack(anchor="w", ipady=2)

            # Réajuste la hauteur si l'utilisateur change de type après ouverture.
            if timing_holder.winfo_ismapped():
                dlg.update_idletasks()
                dlg.geometry(f"460x{dlg.winfo_reqheight()}")

        combo.bind("<<ComboboxSelected>>", _render_timing)
        _render_timing()

        result = {"ok": False, "raw": "", "force": "", "type": "web",
                  "duree": "30", "duree_diapo": "8", "boucles": "1"}

        def _ok(event=None):
            result.update({"ok": True, "raw": combo.get(), "force": force_var.get(),
                           "type": ctx["type"], "duree": duree_var.get(),
                           "duree_diapo": diapo_var.get(), "boucles": boucles_var.get()})
            dlg.destroy()

        # Bindings clavier
        dlg.bind('<Return>', _ok)
        dlg.bind('<Escape>', lambda e: dlg.destroy())

        # Boutons standardisés
        btns = tk.Frame(dlg, bg=Colors.BG_PAGE, padx=20, pady=15)
        btns.pack(side=tk.BOTTOM, fill=tk.X)
        AirbusButton(btns, "Valider", bg=Colors.GREEN, font_size=9, command=_ok).pack(side=tk.RIGHT, ipady=2)
        AirbusButton(btns, "Annuler", outline=True, font_size=9, command=dlg.destroy).pack(side=tk.RIGHT, padx=(0, 10),
                                                                                           ipady=2)

        # Calcul dynamique
        dlg.update_idletasks()
        auto_w = 460
        auto_h = dlg.winfo_reqheight()
        x = self.winfo_rootx() + (self.winfo_width() // 2) - (auto_w // 2)
        y = self.winfo_rooty() + (self.winfo_height() // 2) - (auto_h // 2)
        dlg.geometry(f"{auto_w}x{auto_h}+{x}+{y}")

        # 🚨 FIX ANTI-FREEZE : Sécurisation de l'affichage avant verrouillage
        dlg.deiconify()
        dlg.lift()
        dlg.grab_set()
        dlg.focus_force()

        self.wait_window(dlg)

        # 🚨 FIX ANTI-FREEZE : On restaure la fenêtre parente
        self.attributes('-topmost', True)
        self.grab_set()
        self.focus_force()

        if not result["ok"] or not result["raw"]: return
        name = result["raw"].split(" ", 1)[-1].strip()

        f = result["force"]
        if "@WS" in f:
            prefix = "@WS/"
        elif "@SITE" in f:
            prefix = "@SITE/"
        elif "@GLOBAL" in f:
            prefix = "@GLOBAL/"
        else:
            prefix = ""

        if result.get("type") == "ppt":
            diapo = int(result["duree_diapo"]) if result["duree_diapo"].isdigit() and int(result["duree_diapo"]) >= 1 else 8
            boucles = int(result["boucles"]) if result["boucles"].isdigit() and int(result["boucles"]) >= 1 else 1
            self.draft.setdefault("applications", []).append(
                {"skill": prefix + name, "duree_diapo": diapo, "boucles": boucles})
        else:
            duree = int(result["duree"]) if result["duree"].isdigit() else 30
            self.draft.setdefault("applications", []).append(
                {"skill": prefix + name, "temps_affichage": duree})
        self._mark_dirty()
        self._refresh_screens()

    def _del_app(self, app_idx: int):
        del self.draft["applications"][app_idx]
        self._mark_dirty()
        self._refresh_screens()

    def _move_app(self, app_idx: int, delta: int):
        apps = self.draft["applications"]
        new_idx = app_idx + delta
        if 0 <= new_idx < len(apps):
            apps[app_idx], apps[new_idx] = apps[new_idx], apps[app_idx]
            self._mark_dirty()
            self._refresh_screens()

    def _build_action_bar(self):
        bar = tk.Frame(self, bg=Colors.BG_PAGE)
        bar.pack(side=tk.BOTTOM, fill=tk.X, padx=18, pady=(10, 18))
        AirbusButton(bar, "💾 Sauvegarder", bg=Colors.GREEN, command=self._save).pack(side=tk.RIGHT, padx=(6, 0))
        AirbusButton(bar, "Annuler", outline=True, command=self._on_close).pack(side=tk.RIGHT)

    def _mark_dirty(self):
        self._dirty = True

    def _on_close(self):
        if self._dirty and not messagebox.askyesno("Modifications non sauvegardées", "Fermer sans sauvegarder ?",
                                                   parent=self): return
        self.destroy()

    @show_loading
    def _save(self):
        params = self.draft.setdefault("parametres_globaux", {})
        params["selenium_timeout"] = 15
        if "nom_atelier" in params: del params["nom_atelier"]

        if not self.draft.get("applications"):
            if not messagebox.askyesno("Vide", "Aucun skill. Sauvegarder quand même ?", parent=self): return

        self.draft["type"] = "kiosk"
        self.draft.pop("items", None)
        self.draft.pop("affichage_config", None)  # Nettoie les anciennes structures

        try:
            cfg.save_json(self.config_path, self.draft)
            self._dirty = False
            if self.on_saved: self.on_saved()
            self.destroy()
        except Exception as e:
            messagebox.showerror("Erreur", str(e), parent=self)

