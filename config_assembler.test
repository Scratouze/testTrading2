
"""
ui/views/config_assembler.py — Assembleur de configuration kiosk.

Permet de composer une configuration en :
  - définissant les paramètres globaux (nom_atelier, timeouts, etc.)
  - ajoutant des écrans (monitor_index)
  - pour chaque écran, en référençant des skills avec une durée d'affichage

Les skills sont choisis dans une combobox hiérarchique (WS > SITE > GLOBAL).
"""

import tkinter as tk
from tkinter import ttk
from ui.components import AirbusMessageBox as messagebox
from ui.components import AirbusInputDialog as simpledialog
from typing import Optional, Callable
from copy import deepcopy

from loguru import logger

import config as cfg
import skills
from ui.theme import Colors, Fonts, apply_ttk_styles, Termes
from ui.components import NavBar, AirbusButton, apply_borderless, make_resizable, show_loading


class ConfigAssemblerView(tk.Toplevel):
    """Éditeur de configuration kiosk (type='kiosk')."""

    def __init__(self, parent, base_dir: str, config_path: str, scope: str,
                 site: Optional[str] = None, workspace: Optional[str] = None,
                 on_saved: Optional[Callable] = None):
        super().__init__(parent)
        self.base_dir = base_dir
        self.config_path = config_path
        self.scope = scope
        self.site = site
        self.workspace = workspace
        self.on_saved = on_saved

        self.data = cfg._load_json(config_path)
        if not self.data:
            self.data = {"type": "kiosk", "parametres_globaux": {}, "affichage_config": []}
        self.draft = deepcopy(self.data)
        self.draft.setdefault("affichage_config", [])
        self._dirty = False

        self._available_skills = skills.list_skills_hierarchical(
            base_dir, site, workspace
        )

        # 1. Config de base
        apply_borderless(self)
        self.title(f"{Termes.CAROUSEL} — assembleur")
        self.configure(bg=Colors.BG_PAGE)

        # 2. Forcer au premier plan (SANS le transient)
        self.attributes('-topmost', True)
        self.grab_set()
        self.focus_force()

        # 3. Construire l'interface
        self._setup_ui()
        self._refresh_screens()

        # 4. Positionner au centre de l'écran et afficher
        self.update_idletasks()
        auto_w, auto_h = 820, 660
        x = max(0, (self.winfo_screenwidth() // 2) - (auto_w // 2))
        y = max(0, (self.winfo_screenheight() // 2) - (auto_h // 2))
        self.geometry(f"{auto_w}x{auto_h}+{x}+{y}")
        self.minsize(720, 540)

        apply_ttk_styles(self)
        make_resizable(self, min_width=720, min_height=540)

    def _setup_window(self):
        pass  # Intégré directement dans __init__

    def _set_modal_safe(self):
        try:
            self.transient(self.master)
            self.grab_set()
            logger.info("🔒 [ConfigAssembler] Fenêtre verrouillée au premier plan.")
        except Exception as e:
            logger.error(f"❌ [ConfigAssembler] Échec du verrouillage modal : {e}")

    def _setup_ui(self):
        import os
        name = os.path.basename(self.config_path).replace(".json", "")

        # 1. Ajout du dictionnaire d'émojis
        emoji_map = {"GLOBAL": "🌍 GLOBAL", "SITE": "🏭 SITE", "WS": "🏢️ WS"}
        scope_label = emoji_map.get(self.scope, self.scope)

        NavBar(self, f"Config — {scope_label}", name, close_command=self._on_close)

        # 2. On déclare la barre d'action AVANT le corps de la page
        self._build_action_bar()

        body = tk.Frame(self, bg=Colors.BG_PAGE)
        body.pack(fill=tk.BOTH, expand=True, padx=18, pady=14)

        self._build_screens_block(body)

    # ───────── Paramètres globaux ─────────

    def _build_params_block(self, parent):
        card = tk.Frame(parent, bg=Colors.BG_WHITE,
                        highlightbackground=Colors.BORDER, highlightthickness=1)
        card.pack(fill=tk.X, pady=(0, 12))

        inner = tk.Frame(card, bg=Colors.BG_WHITE, padx=16, pady=12)
        inner.pack(fill=tk.X)

        tk.Label(inner, text="Paramètres globaux",
                 font=(Fonts.MAIN, 10, "bold"), fg=Colors.TXT,
                 bg=Colors.BG_WHITE).pack(anchor="w")

        params = self.draft.setdefault("parametres_globaux", {})

        row = tk.Frame(inner, bg=Colors.BG_WHITE)
        row.pack(fill=tk.X, pady=(8, 0))
        tk.Label(row, text="Nom de l'atelier", font=(Fonts.MAIN, 8, "bold"),
                 fg=Colors.TXT_3, bg=Colors.BG_WHITE, width=22,
                 anchor="w").pack(side=tk.LEFT)
        self.nom_atelier_var = tk.StringVar(value=params.get("nom_atelier", ""))
        self.nom_atelier_var.trace_add("write", lambda *_: self._mark_dirty())
        tk.Entry(row, textvariable=self.nom_atelier_var, font=(Fonts.MAIN, 9),
                 bg=Colors.BG_WHITE, relief="solid", bd=1).pack(
            side=tk.LEFT, fill=tk.X, expand=True
        )

        row2 = tk.Frame(inner, bg=Colors.BG_WHITE)
        row2.pack(fill=tk.X, pady=(4, 0))
        tk.Label(row2, text="Timeout web (secondes)",
                 font=(Fonts.MAIN, 8, "bold"), fg=Colors.TXT_3,
                 bg=Colors.BG_WHITE, width=22, anchor="w").pack(side=tk.LEFT)
        self.timeout_var = tk.StringVar(value=str(params.get("selenium_timeout", 15)))
        self.timeout_var.trace_add("write", lambda *_: self._mark_dirty())
        tk.Entry(row2, textvariable=self.timeout_var, font=(Fonts.MONO, 9),
                 bg=Colors.BG_WHITE, relief="solid", bd=1, width=8).pack(side=tk.LEFT)

