"""
ppt_render.py — Conversion d'un diaporama PowerPoint en page web locale.

Pourquoi ce module ?
    PowerPoint est mono-instance et ne joue qu'un seul diaporama à la fois. Il est
    donc impossible d'afficher un même .pptx (ou des .pptx différents) en "live" sur
    plusieurs écrans simultanément. On contourne cette limite en exportant les diapos
    en images — via le PowerPoint déjà installé sur le poste, en COM, sans accès
    réseau — puis en générant une page HTML autonome qui les fait défiler en plein
    écran. Cette page est ensuite affichée par le moteur via le chemin Chrome par
    moniteur, qui gère déjà parfaitement le multi-écran (un Chrome --kiosk par écran).

Minutage des diapos (par ordre de priorité) :
    1. durée/diapo explicite fournie par l'appelant → uniforme, prioritaire ;
    2. sinon, minutages d'avancement automatique présents dans le .pptx → respectés ;
    3. sinon → durée par défaut uniforme (fallback_slide_s).
    La durée d'affichage totale de l'élément = durée d'un cycle complet × nb de boucles.

Mise en cache :
    La clé de cache combine le chemin absolu, la date de modification, la taille du
    .pptx ET la durée/diapo (qui est figée dans le HTML). Une conversion est donc
    réalisée une fois par (fichier, durée/diapo), refaite seulement si l'un change.

API publique :
    render_ppt_to_web(pptx_path, duree_diapo, boucles, fallback_slide_s, cache_root,
                      force) -> Optional[dict]
        Retourne {"html": <chemin absolu>, "duree_totale_s": <int>} (à utiliser en
        source "file:///...") ou None en cas d'échec (repli géré par l'appelant).
"""

import os
import json
import shutil
import hashlib
from typing import Optional

from loguru import logger


# ── Constantes de module ──────────────────────────────────────────────
_IMG_FILTER = "PNG"                 # filtre graphique PowerPoint
_IMG_EXT = "png"
_EXPORT_LONG_EDGE_PX = 1920         # bord long de l'image exportée (aspect préservé)
_CROSSFADE_MS = 600                 # durée du fondu enchaîné entre 2 diapos
_MIN_SLIDE_MS = 1000                # plancher de durée par diapo (anti-clignotement)
_DEFAULT_SLIDE_S = 8                # durée/diapo par défaut (ni durée fixée, ni minutage)
_CACHE_DIR_NAME = "PptCache"        # sous %LOCALAPPDATA%/KioskEngine/
_WORK_DIR_NAME = "PptWork"          # dossier LOCAL approuvé où copier les .pptx avant ouverture
_OFFICE_VERSIONS = ("16.0", "15.0", "14.0")  # versions Office candidates (LTSC = 16.0)
_DONE_MARKER = ".render_done"       # marqueur de cache complet (anti-cache partiel)
_META_FILENAME = "meta.json"
_HTML_FILENAME = "show.html"
_CACHE_KEY_LEN = 16


# ══════════════════════════════════════════════════════════════════════
# API publique
# ══════════════════════════════════════════════════════════════════════

def render_ppt_to_web(pptx_path: str, duree_diapo: Optional[int] = None,
                      boucles: int = 1, fallback_slide_s: int = _DEFAULT_SLIDE_S,
                      cache_root: Optional[str] = None,
                      force: bool = False) -> Optional[dict]:
    """Convertit (avec cache) un .pptx en page web locale de diapos défilantes.

    Args:
        pptx_path: Chemin du .pptx source (local ou partage UNC).
        duree_diapo: Durée fixe par diapo en secondes. Si fournie (> 0), elle est
            PRIORITAIRE. Sinon on respecte les minutages du fichier, sinon un défaut.
        boucles: Nombre de fois où le diaporama défile avant de passer à l'élément
            suivant (sert à calculer la durée d'affichage totale).
        fallback_slide_s: Durée/diapo par défaut (ni durée fixée, ni minutage natif).
        cache_root: Racine du cache (défaut %LOCALAPPDATA%/KioskEngine/PptCache).
        force: Si True, ignore le cache et reconvertit.

    Returns:
        {"html": <chemin absolu>, "duree_totale_s": <int>} ou None en cas d'échec.
        duree_totale_s = durée d'un cycle complet × boucles.
    """
    if not pptx_path or not os.path.isfile(pptx_path):
        logger.error(f"[PPT→Web] Fichier introuvable : {pptx_path}")
        return None

    boucles = max(1, int(boucles or 1))
    cache_root = _resolve_cache_root(cache_root)

    try:
        cache_key = _cache_key(pptx_path, duree_diapo)
    except OSError as e:
        logger.error(f"[PPT→Web] Accès impossible à {pptx_path} : {e}")
        return None

    out_dir = os.path.join(cache_root, cache_key)
    html_path = os.path.join(out_dir, _HTML_FILENAME)
    done_marker = os.path.join(out_dir, _DONE_MARKER)

    # Cache valide : on réutilise directement (on relit le minutage pour la durée).
    if not force and os.path.isfile(done_marker) and os.path.isfile(html_path):
        slides_meta = _read_meta_slides(out_dir)
        if slides_meta is not None:
            logger.debug(f"[PPT→Web] Cache réutilisé pour '{os.path.basename(pptx_path)}'")
            return {"html": html_path, "duree_totale_s": _total_seconds(slides_meta, boucles)}

    return _convert(pptx_path, duree_diapo, boucles, fallback_slide_s,
                    out_dir, html_path, done_marker)


# ══════════════════════════════════════════════════════════════════════
# Implémentation interne
# ══════════════════════════════════════════════════════════════════════

def _convert(pptx_path: str, duree_diapo: Optional[int], boucles: int,
             fallback_slide_s: int, out_dir: str, html_path: str,
             done_marker: str) -> Optional[dict]:
    """Orchestration : export images + minutage + génération HTML.

    Retourne {"html", "duree_totale_s"} ou None en cas d'échec.
    """
    staged = None
    try:
        # On repart d'un dossier propre pour éviter des diapos obsolètes en cache.
        if os.path.isdir(out_dir):
            shutil.rmtree(out_dir, ignore_errors=True)
        os.makedirs(out_dir, exist_ok=True)

        logger.info(f"[PPT→Web] Conversion de '{os.path.basename(pptx_path)}'...")
        staged = _stage_in_trusted_dir(pptx_path)  # copie locale approuvée (contourne le File Block)
        slides_meta = _export_slides_com(staged or pptx_path, out_dir)
        if not slides_meta:
            logger.error(f"[PPT→Web] Aucune diapo exportée pour {pptx_path}")
            return None

        slides_meta = _apply_slide_durations(slides_meta, duree_diapo, fallback_slide_s)

        _atomic_write_text(html_path, _build_show_html(slides_meta))
        _write_meta(out_dir, pptx_path, slides_meta)

        # Marqueur écrit en dernier : sa présence garantit un cache complet.
        with open(done_marker, "w", encoding="utf-8") as marker:
            marker.write("ok")

        logger.info(f"[PPT→Web] {len(slides_meta)} diapo(s) prêtes : {html_path}")
        return {"html": html_path, "duree_totale_s": _total_seconds(slides_meta, boucles)}

    except Exception as e:
        logger.error(f"[PPT→Web] Échec conversion '{pptx_path}' : {e}")
        return None
    finally:
        # La copie locale n'est plus utile une fois les diapos exportées.
        if staged and os.path.isfile(staged):
            try:
                os.remove(staged)
            except OSError:
                pass


def _export_slides_com(pptx_path: str, out_dir: str) -> list[dict]:
    """Exporte chaque diapo en image et lit son minutage d'avancement automatique.

    L'import de pywin32 (pythoncom / win32com.client) est fait *à l'intérieur* de
    la fonction afin que le module reste importable hors Windows (tests, CI).

    Returns:
        Liste ordonnée [{"file": "slide_001.png", "ms": <int>}, ...]. "ms" vaut 0
        quand la diapo n'a pas de minutage automatique dans le .pptx.
    """
    import pythoncom
    import win32com.client

    pythoncom.CoInitialize()
    powerpoint = None
    presentation = None
    previous_security = None
    try:
        powerpoint = win32com.client.Dispatch("PowerPoint.Application")
        # Mode automatisation : désactive macros + alertes de sécurité (aucun dialogue
        # ne doit figer le kiosque sans surveillance). Restauré dans le finally.
        try:
            previous_security = powerpoint.AutomationSecurity
            powerpoint.AutomationSecurity = 3  # msoAutomationSecurityForceDisable
        except Exception:
            previous_security = None
        presentation = powerpoint.Presentations.Open(
            os.path.abspath(pptx_path), ReadOnly=True, Untitled=False, WithWindow=False
        )

        export_w, export_h = _compute_export_size(presentation)
        slides_meta: list[dict] = []

        for index in range(1, presentation.Slides.Count + 1):
            slide = presentation.Slides(index)
            file_name = f"slide_{index:03d}.{_IMG_EXT}"
            slide.Export(os.path.join(out_dir, file_name),
                         _IMG_FILTER, export_w, export_h)
            slides_meta.append({"file": file_name, "ms": _read_advance_ms(slide)})

        return slides_meta
    finally:
        if powerpoint is not None and previous_security is not None:
            try:
                powerpoint.AutomationSecurity = previous_security  # bonne hygiène (cf. doc MS)
            except Exception:
                pass
        _safe_close(presentation, powerpoint)
        pythoncom.CoUninitialize()


def _compute_export_size(presentation) -> tuple[int, int]:
    """Calcule la taille d'export en pixels en préservant l'aspect de la diapo.

    PageSetup.SlideWidth/SlideHeight sont en points ; on cale le bord long sur
    _EXPORT_LONG_EDGE_PX pour éviter toute déformation (le letterbox final est
    géré côté HTML par background-size: contain).
    """
    try:
        slide_w = float(presentation.PageSetup.SlideWidth)
        slide_h = float(presentation.PageSetup.SlideHeight)
    except Exception:
        slide_w, slide_h = 16.0, 9.0  # repli 16:9 si PageSetup indisponible

    if slide_w <= 0 or slide_h <= 0:
        slide_w, slide_h = 16.0, 9.0

    if slide_w >= slide_h:
        width = _EXPORT_LONG_EDGE_PX
        height = int(round(_EXPORT_LONG_EDGE_PX * slide_h / slide_w))
    else:
        height = _EXPORT_LONG_EDGE_PX
        width = int(round(_EXPORT_LONG_EDGE_PX * slide_w / slide_h))
    return width, height


def _read_advance_ms(slide) -> int:
    """Retourne le minutage d'avancement auto d'une diapo en ms (0 si absent)."""
    try:
        transition = slide.SlideShowTransition
        if transition.AdvanceOnTime and transition.AdvanceTime and transition.AdvanceTime > 0:
            return int(round(float(transition.AdvanceTime) * 1000))
    except Exception:
        return 0
    return 0


def _apply_slide_durations(slides_meta: list[dict], duree_diapo: Optional[int],
                           fallback_slide_s: int) -> list[dict]:
    """Fixe la durée d'affichage de chaque diapo, par ordre de priorité :

      1. durée/diapo explicite (si fournie > 0) → uniforme, PRIORITAIRE ;
      2. sinon, minutages présents dans le .pptx → respectés ;
      3. sinon → durée par défaut uniforme (fallback_slide_s).
    """
    if not slides_meta:
        return slides_meta

    if duree_diapo and duree_diapo > 0:
        fixed_ms = max(_MIN_SLIDE_MS, int(duree_diapo * 1000))
        for slide in slides_meta:
            slide["ms"] = fixed_ms
        return slides_meta

    fallback_ms = max(_MIN_SLIDE_MS, int(fallback_slide_s * 1000))
    has_native_timing = any(slide["ms"] > 0 for slide in slides_meta)

    if has_native_timing:
        for slide in slides_meta:
            slide["ms"] = max(_MIN_SLIDE_MS, slide["ms"] or fallback_ms)
        return slides_meta

    for slide in slides_meta:
        slide["ms"] = fallback_ms
    return slides_meta


def _build_show_html(slides_meta: list[dict]) -> str:
    """Génère une page HTML autonome : défilement plein écran + fondu enchaîné."""
    payload = json.dumps(slides_meta, ensure_ascii=False)
    return (_HTML_TEMPLATE
            .replace("__CROSSFADE_MS__", str(_CROSSFADE_MS))
            .replace("__SLIDES_JSON__", payload))


# ── Emplacement approuvé / mise en scène (postes verrouillés par GPO) ──

def _resolve_work_dir() -> str:
    """Dossier de travail LOCAL (sous %LOCALAPPDATA%) où les .pptx sont copiés."""
    base = os.getenv("LOCALAPPDATA") or os.path.expanduser("~")
    return os.path.join(base, "KioskEngine", _WORK_DIR_NAME)


def _office_version() -> str:
    """Version Office présente (clé PowerPoint dans HKCU), '16.0' par défaut (LTSC)."""
    import winreg
    for ver in _OFFICE_VERSIONS:
        try:
            with winreg.OpenKey(winreg.HKEY_CURRENT_USER,
                                rf"Software\Microsoft\Office\{ver}\PowerPoint"):
                return ver
        except OSError:
            continue
    return "16.0"


def _trusted_locations_globally_disabled(ver: str) -> bool:
    """True si TOUS les emplacements approuvés sont désactivés (stratégie/registre).

    Dans ce cas, enregistrer un emplacement approuvé ne sert à rien : c'est le signal
    qu'il faut une intervention IT (emplacement approuvé GPO) ou un autre moteur.
    """
    import winreg
    candidates = [
        (winreg.HKEY_CURRENT_USER,
         rf"Software\Policies\Microsoft\Office\{ver}\PowerPoint\Security\Trusted Locations"),
        (winreg.HKEY_LOCAL_MACHINE,
         rf"Software\Policies\Microsoft\Office\{ver}\PowerPoint\Security\Trusted Locations"),
        (winreg.HKEY_CURRENT_USER,
         rf"Software\Microsoft\Office\{ver}\PowerPoint\Security\Trusted Locations"),
    ]
    for hive, path in candidates:
        try:
            with winreg.OpenKey(hive, path) as key:
                value, _ = winreg.QueryValueEx(key, "AllLocationsDisabled")
                if int(value) == 1:
                    return True
        except OSError:
            continue
    return False


def _ensure_trusted_location(folder: str) -> bool:
    """Enregistre `folder` comme emplacement approuvé PowerPoint (HKCU, hors stratégie).

    Idempotent. Hors-stratégie → non écrasé par les rafraîchissements GPO. Renvoie
    False si les emplacements approuvés sont globalement désactivés par stratégie.
    """
    import winreg
    ver = _office_version()
    if _trusted_locations_globally_disabled(ver):
        return False

    sub = rf"Software\Microsoft\Office\{ver}\PowerPoint\Security\Trusted Locations\KioskEngineWork"
    try:
        with winreg.CreateKey(winreg.HKEY_CURRENT_USER, sub) as key:
            path_value = folder if folder.endswith("\\") else folder + "\\"
            winreg.SetValueEx(key, "Path", 0, winreg.REG_SZ, path_value)
            winreg.SetValueEx(key, "AllowSubFolders", 0, winreg.REG_DWORD, 1)
            winreg.SetValueEx(key, "Description", 0, winreg.REG_SZ,
                              "KioskEngine - dossier de travail PPT")
        return True
    except OSError as e:
        logger.warning(f"[PPT→Web] Enregistrement de l'emplacement approuvé impossible : {e}")
        return False


def _stage_in_trusted_dir(pptx_path: str) -> Optional[str]:
    """Copie le .pptx dans un dossier LOCAL approuvé puis renvoie le chemin local.

    Sur poste verrouillé (GPO), le « Blocage des fichiers » du Trust Center empêche
    PowerPoint d'ouvrir le .pptx en automatisation. Un fichier situé dans un
    emplacement approuvé échappe au File Block ET à la Vue protégée. On enregistre
    donc (une fois) un dossier local en emplacement approuvé HKCU et on y copie le
    deck avant ouverture. Renvoie None en cas d'échec (repli sur le fichier d'origine).
    """
    try:
        work_dir = _resolve_work_dir()
        os.makedirs(work_dir, exist_ok=True)
        if not _ensure_trusted_location(work_dir):
            logger.warning(
                "[PPT→Web] Emplacements approuvés désactivés par stratégie (GPO) : "
                "l'ouverture risque d'échouer. Demander à l'IT un emplacement approuvé "
                "GPO pour le dossier de contenu, ou une exception de blocage de fichiers."
            )
        local = os.path.join(work_dir, f"staged_{os.getpid()}.pptx")
        shutil.copyfile(pptx_path, local)
        return local
    except Exception as e:
        logger.error(f"[PPT→Web] Mise en scène en zone approuvée impossible : {e}")
        return None


# ── Utilitaires bas niveau ────────────────────────────────────────────

def _resolve_cache_root(cache_root: Optional[str]) -> str:
    """Renvoie la racine de cache (par défaut sous %LOCALAPPDATA%)."""
    if cache_root:
        return cache_root
    base = os.getenv("LOCALAPPDATA") or os.path.expanduser("~")
    return os.path.join(base, "KioskEngine", _CACHE_DIR_NAME)


def _cache_key(pptx_path: str, duree_diapo: Optional[int]) -> str:
    """Clé de cache stable : SHA-256(chemin | mtime | taille | durée/diapo).

    La durée/diapo entre dans la clé : deux usages du même .pptx avec des durées
    différentes produisent deux pages distinctes (le minutage est figé dans le HTML).
    """
    stats = os.stat(pptx_path)
    timing = duree_diapo if (duree_diapo and duree_diapo > 0) else "auto"
    raw = f"{os.path.abspath(pptx_path)}|{int(stats.st_mtime)}|{stats.st_size}|{timing}"
    return hashlib.sha256(raw.encode("utf-8")).hexdigest()[:_CACHE_KEY_LEN]


def _total_seconds(slides_meta: list[dict], boucles: int) -> int:
    """Durée d'affichage totale = somme des durées de diapos × nombre de boucles."""
    cycle_ms = sum(int(slide.get("ms", 0)) for slide in slides_meta)
    return max(1, int(round(cycle_ms * max(1, boucles) / 1000.0)))


def _read_meta_slides(out_dir: str) -> Optional[list[dict]]:
    """Relit les minutages des diapos depuis le meta.json du cache (ou None)."""
    try:
        with open(os.path.join(out_dir, _META_FILENAME), "r", encoding="utf-8") as f:
            return json.load(f).get("slides")
    except Exception:
        return None


def _atomic_write_text(path: str, text: str) -> None:
    """Écriture atomique d'un fichier texte (tmpfile + os.replace + fsync)."""
    tmp_path = f"{path}.tmp.{os.getpid()}"
    try:
        with open(tmp_path, "w", encoding="utf-8") as f:
            f.write(text)
            f.flush()
            os.fsync(f.fileno())
        os.replace(tmp_path, path)
    except Exception:
        if os.path.exists(tmp_path):
            os.unlink(tmp_path)
        raise


def _write_meta(out_dir: str, pptx_path: str, slides_meta: list[dict]) -> None:
    """Écrit un meta.json informatif (debug / traçabilité du cache + minutage)."""
    meta = {"source": os.path.abspath(pptx_path), "slides": slides_meta}
    _atomic_write_text(os.path.join(out_dir, _META_FILENAME),
                       json.dumps(meta, ensure_ascii=False, indent=2))


def _safe_close(presentation, powerpoint) -> None:
    """Ferme proprement la présentation et l'application COM (best-effort)."""
    try:
        if presentation is not None:
            presentation.Close()
    except Exception:
        pass
    try:
        if powerpoint is not None:
            powerpoint.Quit()
    except Exception:
        pass


# ── Gabarit HTML (file:// autonome, aucune ressource externe) ──────────
# NOTE: ceci est un fichier déployé tel quel et ouvert via file:// dans le Chrome
# du kiosque — d'où un document HTML complet (DOCTYPE/html/head/body).
_HTML_TEMPLATE = """<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Diaporama</title>
<style>
  :root { color-scheme: dark; }
  html, body { margin: 0; padding: 0; width: 100%; height: 100%; background: #000; overflow: hidden; }
  .layer {
    position: fixed;
    inset: 0;
    background-color: #000;
    background-position: center center;
    background-repeat: no-repeat;
    background-size: contain;
    opacity: 0;
    transition: opacity __CROSSFADE_MS__ms ease-in-out;
    will-change: opacity;
  }
  .layer.is-active { opacity: 1; }
</style>
</head>
<body>
  <div class="layer" id="layer-a"></div>
  <div class="layer" id="layer-b"></div>
  <script>
    "use strict";
    const SLIDES = __SLIDES_JSON__;

    (function runSlideshow() {
      const layers = [document.getElementById("layer-a"), document.getElementById("layer-b")];
      if (!Array.isArray(SLIDES) || SLIDES.length === 0) { return; }

      let currentIndex = 0;
      let frontLayer = 0;

      function paint(layerIdx, slideIdx) {
        layers[layerIdx].style.backgroundImage = 'url("' + SLIDES[slideIdx].file + '")';
      }

      function preloadNext(slideIdx) {
        // Pre-chargement opportuniste pour un fondu plus fluide (non bloquant).
        const img = new Image();
        img.src = SLIDES[slideIdx].file;
      }

      function advance() {
        const nextIndex = (currentIndex + 1) % SLIDES.length;
        const backLayer = frontLayer === 0 ? 1 : 0;

        paint(backLayer, nextIndex);
        layers[backLayer].classList.add("is-active");
        layers[frontLayer].classList.remove("is-active");

        frontLayer = backLayer;
        currentIndex = nextIndex;
        preloadNext((currentIndex + 1) % SLIDES.length);
        window.setTimeout(advance, SLIDES[currentIndex].ms);
      }

      paint(frontLayer, 0);
      layers[frontLayer].classList.add("is-active");
      preloadNext(SLIDES.length > 1 ? 1 : 0);

      if (SLIDES.length > 1) {
        window.setTimeout(advance, SLIDES[0].ms);
      }

      // Empeche la mise en veille de l'ecran si la politique d'energie l'autorise.
      try {
        if ("wakeLock" in navigator) {
          const requestLock = function () { navigator.wakeLock.request("screen").catch(function () {}); };
          requestLock();
          document.addEventListener("visibilitychange", function () {
            if (document.visibilityState === "visible") { requestLock(); }
          });
        }
      } catch (err) { /* wakeLock indisponible : sans gravite */ }
    })();
  </script>
</body>
</html>
"""
