# ══════════════════════════════════════════════════════════════════════
# REDÉMARRAGE / ARRÊT
# ══════════════════════════════════════════════════════════════════════

def restart_app(new_config: str | None = None, clear_profile: bool = False, index: int | None = None):
    """Prépare l'arrêt pour laisser le script .bat faire la mise à jour, ou s'auto-relance en dev."""
    logger.info("Ordre de REDÉMARRAGE initié...")
    state.shutdown_event.set()

    # --- 1. SAUVEGARDE DE LA NOUVELLE CONFIG (Transmission au .bat / prochain lancement) ---
    config_to_run = new_config or getattr(state, 'active_config_path', state.active_config_name)
    if config_to_run:
        appdata_dir = os.getenv('LOCALAPPDATA')
        autorun_file = os.path.join(appdata_dir, "KioskEngine_App", "next_autorun.txt")
        os.makedirs(os.path.dirname(autorun_file), exist_ok=True)
        try:
            with open(autorun_file, "w", encoding="utf-8") as f:
                f.write(config_to_run)
            logger.info(f"Fichier next_autorun.txt écrit avec succès : {config_to_run}")
        except Exception as e:
            logger.error(f"Erreur lors de l'écriture de next_autorun.txt : {e}")

    # --- 2. NETTOYAGE DES PROCESSUS ---
    import time
    time.sleep(1.0)
    from managers import process_manager
    process_manager.kill_all_tracked()

    if clear_profile:
        import shutil
        appdata_dir = os.getenv('LOCALAPPDATA')
        profile_base_dir = os.path.join(appdata_dir, "KioskEngine")
        try:
            time.sleep(1)
            shutil.rmtree(profile_base_dir, ignore_errors=True)
            logger.info("🧹 Profil Chrome nettoyé !")
        except Exception:
            pass

    time.sleep(2.0)

    import sys, subprocess
    is_frozen = getattr(sys, 'frozen', False)

    if not is_frozen:
        logger.info("Mode DEV détecté : Auto-relance interne via Python...")
        safe_cwd = os.path.dirname(os.path.abspath(__file__))
        commande = [sys.executable, os.path.abspath(__file__)]

        skip_next = False
        for arg in sys.argv[1:]:
            if skip_next:
                skip_next = False
                continue
            if arg in ["--autorun", "--index"]:
                skip_next = True
                continue
            commande.append(arg)

        subprocess.Popen(commande, cwd=safe_cwd)
    else:
        logger.info("Mode PROD détecté : Arrêt total pour laisser le .bat synchroniser.")
        os._exit(2)
    os._exit(0)

def on_quit(control_panel_window, tracker=None):
    """Arrêt propre de l'application."""
    logger.info("🛑 Demande d'arrêt initiée...")
    state.shutdown_event.set()
    state.pause_event.set()

    if tracker:
        tracker.cleanup()
        logger.info("✓ Tracker réseau désactivé.")

    logger.info("🧹 Nettoyage des processus enfants (Chrome, Node, etc.)...")
    process_manager.kill_all_tracked()

    try:
        banners = getattr(state.app_root, "_app_banners", [])
        for b in banners:
            if b is not None and b.winfo_exists():
                b.destroy()
    except Exception:
        pass

    # --- LE RETOUR DU BLOC INTELLIGENT ---
    if is_admin_open():
        logger.warning("🛡️ Le Dashboard Admin est ouvert : Le Kiosque s'arrête, mais l'application reste active.")
        state.pending_full_exit = True
        try:
            if control_panel_window:
                control_panel_window.destroy()
        except Exception:
            pass
        return

    logger.info("💀 Arrêt définitif de l'application Tkinter.")
    try:
        if hasattr(state, 'app_root') and state.app_root:
            state.app_root.destroy()
        else:
            if control_panel_window:
                control_panel_window.destroy()
    except Exception:
        pass

    process_manager.kill_all_tracked()
    logger.info("✅ Kiosk Engine fermé avec succès.")

    import os
    os._exit(0)
# ══════════════════════════════════════════════════════════════════════
# HELPERS DE DÉMARRAGE (extraits pour lisibilité)
# ══════════════════════════════════════════════════════════════════════

def _parse_cli() -> tuple[str, str | None, str | None, str | None]:
    """Parse les arguments CLI. Retourne (base_dir, autorun, site, workspace)."""
    args = sys.argv[1:]

    def _pop_arg(name):
        nonlocal args
        if name in args:
            idx = args.index(name)
            if idx + 1 < len(args):
                val = args[idx + 1]
                del args[idx:idx + 2]
                return val
        return None

    autorun = _pop_arg("--autorun")
    cli_site = _pop_arg("--site")
    cli_ws = _pop_arg("--workspace")


    if not autorun:
        appdata_dir = os.getenv('LOCALAPPDATA')
        autorun_file = os.path.join(appdata_dir, "KioskEngine_App", "next_autorun.txt")
        if os.path.exists(autorun_file):
            try:
                with open(autorun_file, "r", encoding="utf-8") as f:
                    autorun = f.read().strip()
                os.remove(autorun_file)  # On le supprime pour ne le lire qu'une seule fois
            except Exception:
                pass


    if args:
        base_dir = args[0]
    elif getattr(sys, 'frozen', False):
        base_dir = os.path.dirname(sys.executable)
    else:
        base_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))

    # TODO Base url AA ou AO
    # AO
    base_dir = r"\\sfs.corp\Apps\MANUFACTURING\Shopfloor Digit\Affichage Atelier\KioskEngine"

    # AA
    # base_dir = r"\\mycorp.corp\dfs\PrepMethodes\Services\PSE_Shopfloor_Execution\ATLANTIC\Affichage Atelier\KioskEngine"
    return base_dir, autorun, cli_site, cli_ws


def _setup_logger(base_dir: str):
    """Configure loguru : console (si TTY) + fichier rotatif par poste."""
    log_dir = os.path.join(base_dir, "logs")
    os.makedirs(log_dir, exist_ok=True)
    pc_name = socket.gethostname()
    log_file = os.path.join(log_dir, f"kiosk_{pc_name}.log")

    logger.remove()
    if sys.stdout is not None and hasattr(sys.stdout, "isatty") and sys.stdout.isatty():
        logger.add(
            sys.stdout, colorize=True,
            format="<green>{time:YYYY-MM-DD HH:mm:ss}</green> | "
                   "<level>{level: <8}</level> | "
                   "<cyan>{thread.name: <15}</cyan> | "
                   "<magenta>{name}:{function}:{line}</magenta> - <level>{message}</level>"
        )
    logger.add(log_file, rotation="5 MB", retention=3, encoding="utf-8", level="INFO")


def _auto_detect_site_ws(scope, base_dir: str) -> tuple[str | None, str | None]:
    """
    Auto-détecte site/workspace si non résolu via scope :
    - Si un seul site/ws existe, on le prend
    - Sinon on prend le premier trouvé (fallback permissif)
    """
    site = scope.kiosk_site
    ws = scope.kiosk_workspace

    if not site or not ws:
        sites = cfg.list_sites(base_dir)
        if len(sites) == 1:
            site = site or sites[0]
            workspaces = cfg.list_workspaces(base_dir, site)
            if len(workspaces) == 1:
                ws = ws or workspaces[0]

    if not site or not ws:
        logger.warning("Site/workspace non résolu. Fallback sur le premier disponible.")
        for s in cfg.list_sites(base_dir):
            for w in cfg.list_workspaces(base_dir, s):
                site, ws = s, w
                break
            if site:
                break

    return site, ws


def _resolve_autorun(autorun: str | None, toutes_configs: dict[str, str]) -> str | None:
    """Résout --autorun vers un chemin absolu, ou None si introuvable."""
    if not autorun:
        return None
    if os.path.isabs(autorun) and os.path.exists(autorun):
        return autorun
    for display_name, full_path in toutes_configs.items():
        if os.path.basename(full_path) == autorun or display_name == autorun:
            return full_path
    logger.warning(f"Config autorun '{autorun}' introuvable dans la hiérarchie.")
    return None


def _load_and_compile(chemin_config: str, global_config: dict, base_dir: str,
                       site: str | None, ws: str | None) -> dict:
    """
    Charge + valide (Pydantic) + compile (résolution skills + playlist).
    Retourne une config prête pour l'engine.
    """
    from models import RawKioskConfig
    from pydantic import ValidationError

    raw = cfg.charger_config(chemin_config, global_config)

    try:
        RawKioskConfig(**raw)
    except ValidationError as e:
        logger.critical("❌ Erreur de structure dans le fichier JSON ! Démarrage annulé.")
        for error in e.errors():
            loc = " -> ".join([str(x) for x in error['loc']])
            logger.error(f"  → Champ [{loc}] : {error['msg']}")
        raise ValueError("Configuration JSON invalide (structure/types).")

    try:
        return compile_config(base_dir, raw, global_config, site=site, workspace=ws)
    except CompilationError as e:
        logger.critical(f"❌ Échec de la compilation : {e}")
        raise ValueError(f"Configuration non compilable : {e}")


# ══════════════════════════════════════════════════════════════════════
# MAIN
# ══════════════════════════════════════════════════════════════════════

def main():
    try:
        base_dir, autorun_config, cli_site, cli_ws = _parse_cli()

        _setup_logger(base_dir)
        pc_name = socket.gethostname()
        logger.info(f"Base dir : {base_dir}")
        logger.info(f"Logs réseau activés pour le poste : {pc_name}")

        global_config = cfg.load_global_config(base_dir)

        root = tk.Tk()
        root.withdraw()
        state.app_root = root

        chemin_icone = os.path.join(base_dir, "assets", "icon.ico")
        if os.path.exists(chemin_icone):
            try:
                root.iconbitmap(default=chemin_icone)
            except Exception as e:
                logger.warning(f"Impossible de charger l'icône : {e}")

        if cli_site:
            os.environ["KIOSK_SITE"] = cli_site
        if cli_ws:
            os.environ["KIOSK_WORKSPACE"] = cli_ws

        # ── RÉSOLUTION DU SCOPE RBAC ──
        scope = cfg.resolve_user_scope(base_dir)
        state.current_scope = scope
        logger.info(
            f"Scope résolu : {scope.role} | "
            f"site={scope.kiosk_site} | ws={scope.kiosk_workspace}"
        )

        kiosk_site, kiosk_ws = _auto_detect_site_ws(scope, base_dir)
        state.current_scope.kiosk_site = kiosk_site
        state.current_scope.kiosk_workspace = kiosk_ws

        configs_dir = base_dir

        # ── SÉLECTION DE LA CONFIG ──
        toutes_configs = cfg.list_all_launchables_hierarchical(base_dir, kiosk_site, kiosk_ws)
        chemin_config = _resolve_autorun(autorun_config, toutes_configs)

        # ── DÉBUT CASCADE LANCEMENT AUTO ──
        if not chemin_config:
            mapping = cfg.load_poste_mapping(base_dir)
            pc_name = socket.gethostname()

            # 1. Mapping Poste (Priorité absolue - Sur mesure)
            defaut_pc = mapping.get(pc_name, {}).get("config_par_defaut")
            if defaut_pc:
                chemin_config = _resolve_autorun(defaut_pc, toutes_configs)
                if chemin_config: logger.info(f"Cascade [1/3] : Lancement Auto du POSTE -> {defaut_pc}")

            # 2. Workspace (Norme de l'atelier)
            if not chemin_config and kiosk_site and kiosk_ws:
                wc = cfg.load_workspace_config(base_dir, kiosk_site, kiosk_ws)
                defaut_ws = wc.get("config_par_defaut")
                if defaut_ws:
                    chemin_config = _resolve_autorun(defaut_ws, toutes_configs)
                    if chemin_config: logger.info(f"Cascade [2/3] : Lancement Auto du WORKSPACE -> {defaut_ws}")

            # 3. Site (Norme de l'usine)
            if not chemin_config and kiosk_site:
                sc = cfg.load_site_config(base_dir, kiosk_site)
                defaut_site = sc.get("config_par_defaut")
                if defaut_site:
                    chemin_config = _resolve_autorun(defaut_site, toutes_configs)
                    if chemin_config: logger.info(f"Cascade [3/3] : Lancement Auto du SITE -> {defaut_site}")

            # 4. Mode Manuel (Si aucune règle n'a été trouvée)
            if not chemin_config:
                selector = ConfigSelectorView(root, configs_dir, base_dir)
                chemin_config = selector.get_selection()

            if not chemin_config:
                # 🚨 FIX : On vérifie si l'admin est ouvert avant de tout détruire !
                if is_admin_open():
                    logger.info("Le sélecteur a été fermé, mais l'Admin est actif. Maintien du processus.")
                    # On signale à l'état global que la fermeture de l'Admin devra couper tout le programme
                    state.pending_full_exit = True
                    root.mainloop()  # On maintient l'application en vie
                    os._exit(0)
                else:
                    logger.info("Aucune configuration sélectionnée. Arrêt.")
                    try:
                        root.destroy()
                    except Exception:
                        pass
                    sys.exit(0)

        state.active_config_name = os.path.basename(chemin_config)
        state.active_config_path = chemin_config
        logger.info(f"Chargement : {chemin_config}")

        # ── SPLASH (affiché AVANT la compilation) ──
        # La compilation peut convertir des présentations PowerPoint (plusieurs
        # secondes). On crée le splash maintenant pour donner un retour visuel dès le
        # lancement, au lieu de laisser un écran figé pendant la conversion.
        splash = SplashScreenView(master=root)
        splash.set_status("Chargement de la configuration...")
        splash.set_progress(2)
        try:
            root.update()
        except tk.TclError:
            pass

        # On relie la progression de la conversion PPT au splash. La compilation tourne
        # sur le thread principal : le callback peut donc mettre à jour le splash et
        # pomper la boucle Tk directement (même schéma que les phases moniteurs/warmup).
        from ppt_render import set_progress_callback as _ppt_set_progress_cb

        _compile_pct = [2.0]            # progression courante (liste = mutable en closure)
        _COMPILE_PCT_CAP = 50.0         # plafond réservé à la phase compilation/conversion

        def _on_compile_progress(message, fraction=None):
            # Avance la barre de façon monotone vers le plafond (sans connaître le nombre
            # total de présentations) puis pompe la boucle Tk pour rafraîchir l'affichage.
            _compile_pct[0] += (_COMPILE_PCT_CAP - _compile_pct[0]) * 0.18
            try:
                splash.set_status(message)
                splash.set_progress(_compile_pct[0])
                root.update()
            except tk.TclError:
                pass

        _ppt_set_progress_cb(_on_compile_progress)

        # ── CHARGEMENT + VALIDATION + COMPILATION ──
        try:
            config = _load_and_compile(chemin_config, global_config, base_dir,
                                       kiosk_site, kiosk_ws)
        finally:
            _ppt_set_progress_cb(None)  # on débranche le hook quoi qu'il arrive

        param_globaux = config.get("parametres_globaux", {})
        param_globaux["base_dir"] = base_dir

        # ── VALIDATION SÉCURITÉ ──
        errors = validate_config(config, global_config)
        if errors:
            logger.error(f"Validation sécurité — {len(errors)} problème(s) bloquant(s) :")
            for err in errors:
                logger.error(f"  → {err}")
            raise ValueError("Configuration non sécurisée. Corrigez avant lancement.")


        # ── BANNER ── (le splash a déjà été créé avant la compilation)
        splash.set_status("Préparation du lancement...")
        splash.set_progress(52)

        pc_name = socket.gethostname()
        mapping = cfg.load_poste_mapping(base_dir)
        nom_poste = mapping.get(pc_name, {}).get("nom", "")

        affichage_poste = nom_poste if nom_poste else pc_name
        texte_banniere = f"{kiosk_site} / {kiosk_ws}  —   {affichage_poste}"

        liste_ecrans = config.get("affichage_config", [])
        is_admin = state.current_scope.is_any_admin

        moniteurs_utilises = set()
        for ecran in liste_ecrans:
            moniteurs_utilises.add(ecran.get("monitor_index", 1))

        if not moniteurs_utilises:
            moniteurs_utilises.add(1)

        root._app_banners = []
        for m_idx in moniteurs_utilises:
            banner = AppBannerView(root, texte_banniere, monitor_index=m_idx, show_buttons=not is_admin,
                                   base_dir=base_dir)
            root._app_banners.append(banner)


        # ── THREADS MONITEURS ──
        ecrans = config.get("affichage_config", [])
        total_ecrans = max(1, len(ecrans))
        for i, ecran in enumerate(ecrans, start=1):
            idx = ecran.get("monitor_index", 1)
            apps = ecran.get("applications", [])
            splash.set_status(f"Démarrage du moniteur {idx}...")
            splash.set_progress(52 + (20 * i / total_ecrans))

            t = threading.Thread(
                target=thread_moniteur,
                args=(idx, apps, param_globaux, kiosk_site or "", kiosk_ws or ""),
                daemon=True,
            )
            t.start()
            try:
                root.update_idletasks()
                root.update()
            except tk.TclError:
                pass

        # ── WARMUP ──
        splash.set_status("Initialisation des systèmes...")
        warmup_duration = 5.5
        warmup_start = time.monotonic()
        while True:
            elapsed = time.monotonic() - warmup_start
            if elapsed >= warmup_duration:
                break
            splash.set_progress(72 + ((elapsed / warmup_duration) * 25))
            try:
                root.update_idletasks()
                root.update()
            except tk.TclError:
                break
            time.sleep(0.05)

        splash.set_status("Interface prête")
        splash.set_progress(100)
        try:
            root.update_idletasks()
            root.update()
        except tk.TclError:
            pass
        time.sleep(0.15)
        splash.destroy()

        # ── TRACKER + CONTROL PANEL ──
        nom_fichier = os.path.basename(chemin_config)
        tracker = None
        if kiosk_site and kiosk_ws:
            tracker = InstanceTracker(
                base_dir=base_dir,
                nom_config=nom_fichier,
                site_name=kiosk_site,
                ws_name=kiosk_ws,
                global_config=global_config,
                restart_callback=restart_app,
            )

        for b in root._app_banners:
            b.on_stop = lambda: on_quit(None, tracker)

        if state.current_scope.is_any_admin:
            ControlPanelView(
                master=root,
                base_dir=base_dir,
                nom_fichier=nom_fichier,
                tracker=tracker,
                on_quit_callback=on_quit,
            )

        root.mainloop()

    except Exception as e:
            logger.critical(f"Erreur fatale : {e}")
            try:
                # Le splash (topmost) a pu être créé avant la compilation : on le retire
                # pour ne pas masquer la boîte d'erreur.
                if 'splash' in locals() and splash:
                    splash.destroy()
            except Exception:
                pass
            try:
                from tkinter import messagebox
                err_root = tk.Tk()
                err_root.withdraw()
                err_root.attributes('-topmost', True)
                messagebox.showerror("Erreur Fatale", f"Impossible de démarrer :\n{e}", parent=err_root)
                err_root.destroy()
            except Exception:
                pass
            try:
                if 'root' in locals() and root:
                    root.destroy()
            except Exception:
                pass
            sys.exit(1)

if __name__ == "__main__":
    base_dir_param = sys.argv[1] if len(sys.argv) > 1 else r"\\Serveur\KiosquePartage"

    _appliquer_securites_demarrage(base_dir_param)
    main()
