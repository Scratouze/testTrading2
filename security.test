
"""
security.py — Module de sécurité pour Kiosk Engine.

Contient :
- HMAC-SHA256 pour authentifier les commandes distantes (.cmd)
- Chiffrement / déchiffrement des identifiants (DPAPI Windows)
- Validation des séquences send_keys (blacklist de patterns dangereux)
- Whitelist de domaines, exécutables, variables d'environnement
- Vérification d'intégrité de ChromeDriver (hash SHA-256)
"""

import os
import re
import hmac
import time
import hashlib
import ipaddress
import threading
from typing import Optional
from urllib.parse import urlparse
from loguru import logger

# Préfixe pour les identifiants chiffrés dans les configs
ENC_PREFIX = "ENC:"


# ══════════════════════════════════
# HMAC — AUTHENTIFICATION DES COMMANDES
# ══════════════════════════════════

def _get_hmac_secret(global_config: dict) -> Optional[bytes]:
    """Récupère le secret HMAC (clé directe ou variable d'environnement)."""
    # On lit la valeur configurée dans l'Admin
    configured_val = global_config.get("security", {}).get("hmac_secret_env", "")

    if not configured_val:
        logger.warning("Aucun secret HMAC configuré. Les commandes distantes ne seront PAS authentifiées.")
        return None
    secret = os.environ.get(configured_val)

    if not secret:
        secret = configured_val

    return secret.encode('utf-8')


def sign_command(command_text: str, global_config: dict) -> str:
    """
    Signe une commande avec HMAC-SHA256 + horodatage.

    Format retourné :
        RESTART_WITH config.json
        TIMESTAMP:1719500000
        HMAC:a3f2b8c9...
    """
    secret = _get_hmac_secret(global_config)
    timestamp = str(int(time.time()))
    payload = f"{command_text}\nTIMESTAMP:{timestamp}"

    if secret:
        sig = hmac.new(secret, payload.encode('utf-8'), hashlib.sha256).hexdigest()
        return f"{payload}\nHMAC:{sig}"
    else:
        return f"{payload}\nHMAC:UNSIGNED"


def verify_command(file_content: str, global_config: dict, max_age_seconds: int = 60) -> Optional[str]:
    """
    Vérifie une commande signée. Retourne la commande si valide, None sinon.

    Vérifie :
    - Signature HMAC
    - Horodatage (anti-rejeu, max 60s par défaut)
    """
    lines = file_content.strip().split('\n')
    if len(lines) < 3:
        # Format ancien (non signé) — accepter si pas de secret configuré
        secret = _get_hmac_secret(global_config)
        if secret is None:
            return lines[0].strip() if lines else None
        logger.warning("Commande non signée rejetée (HMAC configuré).")
        return None

    command = lines[0].strip()
    timestamp_line = lines[1].strip()
    hmac_line = lines[2].strip()

    if not timestamp_line.startswith("TIMESTAMP:") or not hmac_line.startswith("HMAC:"):
        logger.warning("Format de commande invalide.")
        return None

    received_hmac = hmac_line.split("HMAC:", 1)[1]

    # Vérification de l'horodatage
    try:
        ts = int(timestamp_line.split("TIMESTAMP:", 1)[1])
        age = abs(time.time() - ts)
        if age > max_age_seconds:
            logger.warning(f"Commande expirée (âge: {age:.0f}s, max: {max_age_seconds}s).")
            return None
    except (ValueError, IndexError):
        logger.warning("Horodatage invalide dans la commande.")
        return None

    # Vérification HMAC
    secret = _get_hmac_secret(global_config)
    if secret is None:
        if received_hmac == "UNSIGNED":
            return command
        logger.warning("HMAC présent mais aucun secret configuré.")
        return command  # Accepter en mode dégradé

    payload = f"{command}\n{timestamp_line}"
    expected = hmac.new(secret, payload.encode('utf-8'), hashlib.sha256).hexdigest()

    if not hmac.compare_digest(received_hmac, expected):
        logger.warning(f"HMAC invalide pour la commande '{command}'. Rejet.")
        return None

    return command


